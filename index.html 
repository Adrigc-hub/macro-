<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Roblox Macro & Bot Lab</title>
    <style>
        body { background: #121212; color: #fff; font-family: sans-serif; display: flex; flex-direction: column; align-items: center; padding: 10px; }
        .controls { background: #222; padding: 15px; border-radius: 10px; margin-bottom: 10px; width: 100%; max-width: 400px; display: flex; gap: 10px; flex-wrap: wrap; }
        .game-area { width: 100%; max-width: 400px; height: 300px; background: #000; border: 2px solid #555; position: relative; overflow: hidden; }
        .item { width: 40px; height: 40px; background: gold; position: absolute; border-radius: 5px; cursor: pointer; border: 2px solid #fff; }
        .log { width: 100%; max-width: 400px; height: 100px; background: #000; color: #0f0; padding: 10px; overflow-y: scroll; font-size: 12px; margin-top: 10px; }
        button { padding: 10px; flex: 1; border: none; cursor: pointer; font-weight: bold; }
    </style>
</head>
<body>

<h3>Macro Laboratorio</h3>
<div class="controls">
    <button onclick="setMode('RECORD')" style="background:red;">GRABAR</button>
    <button onclick="setMode('PLAY')" style="background:green;">REPRODUCIR</button>
    <button onclick="setMode('DETECT')" style="background:gold;">MODO SMART (AUTO-CLAIM)</button>
    <button onclick="spawnItem()" style="background:#444; color:white;">SPAWN OBJETO</button>
</div>

<div class="game-area" id="gameArea"></div>
<div class="log" id="console">Modo: Esperando...</div>

<script>
    const area = document.getElementById('gameArea');
    const logs = document.getElementById('console');
    let mode = 'IDLE'; // RECORD, PLAY, DETECT
    let macro = [];
    let startTime;

    function log(msg) { logs.innerHTML += `> ${msg}<br>`; logs.scrollTop = logs.scrollHeight; }

    function setMode(newMode) {
        mode = newMode;
        log("Cambiado a: " + mode);
        if(mode === 'RECORD') macro = [];
        if(mode === 'DETECT') startSmartDetection();
    }

    // --- MODO 1: GRABADOR ---
    area.addEventListener('mousedown', (e) => {
        if(mode === 'RECORD') {
            const rect = area.getBoundingClientRect();
            macro.push({ x: e.clientX - rect.left, y: e.clientY - rect.top, time: Date.now() - startTime });
            log("Grabado click");
        }
    });

    function setMode(m) {
        mode = m;
        if(mode === 'RECORD') { startTime = Date.now(); log("Grabando..."); }
        if(mode === 'PLAY') playMacro();
    }

    async function playMacro() {
        for(let step of macro) {
            await new Promise(r => setTimeout(r, 500)); // Simula delay
            clickAt(step.x, step.y);
        }
    }

    // --- MODO 2: INTELIGENTE (DETECTOR) ---
    function startSmartDetection() {
        log("Escaneando items...");
        setInterval(() => {
            if(mode !== 'DETECT') return;
            const items = document.querySelectorAll('.item');
            items.forEach(item => {
                log("¡Item detectado! Reclamando...");
                item.click();
            });
        }, 1000); // Escanea cada segundo
    }

    // Simula clicks y eliminación de objetos
    function clickAt(x, y) {
        const el = document.createElement('div');
        el.style.position = 'absolute';
        el.style.left = x + 'px'; el.style.top = y + 'px';
        el.style.background = 'white'; el.style.width = '10px'; el.style.height = '10px';
        area.appendChild(el);
        setTimeout(() => el.remove(), 200);
    }

    function spawnItem() {
        const item = document.createElement('div');
        item.className = 'item';
        item.style.left = Math.random() * (350) + 'px';
        item.style.top = Math.random() * (250) + 'px';
        item.onclick = function() { this.remove(); log("Item recolectado!"); };
        area.appendChild(item);
    }
</script>
</body>
</html>
